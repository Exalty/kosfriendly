generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String       @id @default(cuid())
  nama       String
  email      String       @unique
  password   String
  role       Role         @default(PELANGGAN)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  kamarId    String?
  absensi    Absensi[]
  komplain   Komplain[]
  pembayaran Pembayaran[]
  kamar      Kamar?       @relation(fields: [kamarId], references: [id])
}

model Komplain {
  id        String         @id @default(cuid())
  subjek    String
  deskripsi String
  status    StatusKomplain @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Kamar {
  id         String   @id @default(cuid())
  nomorKamar String   @unique
  tipe       String
  harga      Int
  fasilitas  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  penghuni   User[]

  @@map("Kamar")
}

model Pembayaran {
  id         String      @id @default(cuid())
  jumlah     Int
  metode     String
  buktiBayar String?
  status     StatusBayar @default(PENDING)
  catatan    String?
  userId     String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Absensi {
  id        String        @id @default(cuid())
  tanggal   DateTime      @default(now())
  status    StatusAbsensi @default(HADIR)
  catatan   String?
  userId    String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum StatusAbsensi {
  HADIR
  IZIN
  ALFA
}

enum Role {
  ADMIN
  PEMILIK
  PELANGGAN
  PETUGAS
}

enum StatusKomplain {
  PENDING
  PROSES
  SELESAI
}

enum StatusBayar {
  PENDING
  BERHASIL
  GAGAL
}
